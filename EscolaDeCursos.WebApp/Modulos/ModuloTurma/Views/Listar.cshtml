@using EscolaDeCursos.Dominio.Modulos.ModuloTurma
@model ListarTurmasPaginaViewModel
@{
  Layout = "_Layout";
  ViewBag.Titulo = "👥 Turmas";
  ViewBag.Info = "Cadastre, visualize e gerencie turmas.";
  ViewBag.TextoBotao = "Cadastrar Turma";
  ViewBag.ControllerBotao = "Turma";
  ViewBag.ActionBotao = "Cadastrar";
}

<form method="get" asp-action="Listar" class="row g-2 align-items-end mb-4 mt-1">
  <div class="col-md-4">
    <label asp-for="CursoId" class="form-label fw-semibold text-body-secondary small">Curso</label>
    <select asp-for="CursoId" class="form-select"
      asp-items='@(new SelectList(Model.Cursos ?? new List<OpcaoCursoViewModel>(), "Id", "Titulo"))'>
      <option value="">Todas</option>
    </select>
  </div>
  <div class="col-md-4">
    <label asp-for="FiltroCapacidade" class="form-label fw-semibold text-body-secondary small">Capacidade</label>
    <select asp-for="FiltroCapacidade" class="form-select"
      asp-items="Html.GetEnumSelectList<FiltroCapacidadeTurma>()">
      <option value="">Todas</option>
    </select>
  </div>
  <div class="col-md-auto">
    <button type="submit" class="btn btn-dark">Filtrar</button>
  </div>
</form>

<hr>

@if (TempData["MensagemErro"] is string mensagemErro)
{
  <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
    @mensagemErro
  </div>
}

@if (Model.Turmas.Count == 0)
{
  <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
    @(Model.FiltroCapacidade is null && (Model.CursoId is null || Model.CursoId == Guid.Empty)
      ? "Nenhuma turma cadastrada."
      : "Nenhuma turma encontrada para este filtro.")
  </div>
}
else
{
  <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2 mt-2">
    @foreach (ListarTurmasViewModel t in Model.Turmas)
    {
      <div class="col">
        <div class="card h-100">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-3">
              <h5 class="card-title fw-semibold text-dark medium">@t.Nome</h5>
            </div>
            <hr class="my-1">

            <dl class="row g-2 mb-4 mt-2">
              <dt class="col-4 text-body-secondary fw-bold">Curso:</dt>
              <dd class="col-8 mb-0 text-break">@t.CursoTitulo</dd>

              <dt class="col-4 text-body-secondary fw-bold">Instrutor:</dt>
              <dd class="col-8 mb-0 text-break">@t.InstrutorNome</dd>

              <dt class="col-4 text-body-secondary fw-bold">Capacidade:</dt>
              <dd class="col-8 mb-0">@t.CapacidadeMaxima</dd>

              <dt class="col-4 text-body-secondary fw-bold">Início:</dt>
              <dd class="col-8 mb-0">@t.DataInicio.ToString("dd/MM/yyyy")</dd>

              <dt class="col-4 text-body-secondary fw-bold">Término:</dt>
              <dd class="col-8 mb-0">@t.DataTermino.ToString("dd/MM/yyyy")</dd>
            </dl>

            <div class="d-flex flex-wrap gap-2 mt-auto justify-content-between align-items-center">
              <div class="d-flex flex-wrap gap-2">
                <a asp-action="excluir" asp-route-id="@t.Id" class="btn btn-danger" title="Excluir">
                  <i class="bi bi-trash"></i>
                </a>
                <a asp-action="editar" asp-route-id="@t.Id" class="btn btn-success" title="Editar">
                  <i class="bi bi-pencil-square"></i>
                </a>
              </div>
              <a asp-controller="Matricula" asp-action="Listar" asp-route-turmaId="@t.Id" class="btn btn-primary"
                title="Detalhes">
                <i class="bi bi-people px-1"></i> Matrículas
              </a>
            </div>
          </div>
        </div>
      </div>
    }
  </div>
}
