@{
Layout = "_Layout";
ViewBag.Titulo = "🗑️ Excluir Turma";
ViewBag.Info = "Tem certeza de que deseja excluir esta turma?";
}

@model ExcluirTurmaViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4 bg-transparent" style="max-width: 620px;">
    <div class="alert alert-warning border-start border-primary border-1 rounded-3" role="alert">
        Deseja realmente excluir esta turma?
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">Nome da Turma</label>
        <input type="text" class="form-control" value="@Model.Nome" disabled>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">Instrutor</label>
        <input type="text" class="form-control" value="@(Model.InstrutorNome ?? " Não informado")" disabled>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">Capacidade Máxima</label>
        <input type="text" class="form-control" value="@Model.CapacidadeMaxima" disabled>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label class="form-label fw-semibold text-primary text-uppercase small">Data de Início</label>
            <input type="text" class="form-control" value="@Model.DataInicio.ToString(" dd/MM/yyyy")" disabled>
        </div>
        <div class="col-md-6">
            <label class="form-label fw-semibold text-primary text-uppercase small">Data de Término</label>
            <input type="text" class="form-control" value="@Model.DataTermino.ToString(" dd/MM/yyyy")" disabled>
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-secondary rounded-2 px-4" asp-action="Listar">Voltar</a>
        <button class="btn btn-primary rounded-2 px-4" type="submit">Confirmar</button>
    </div>
</form>
</div>