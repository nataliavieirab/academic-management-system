@{
  Layout = "_Layout";
  ViewData["BodyClass"] = "page-mint";
  ViewBag.Titulo = "📝 Cadastrar";
  ViewBag.Info = "Cadastre sua instituição em poucos passos e comece a organizar toda a gestão acadêmica em um só lugar.";
}

@model RegistrarViewModel

<form class="card border shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Registrar"
      method="post">
  <div asp-validation-summary="ModelOnly" class="text-danger small fw-semibold mb-3"></div>

  <div class="mb-3">
    <label asp-for="Nome" class="form-label fw-semibold text-primary text-uppercase small">Nome da Instituição</label>
    <input asp-for="Nome" type="text" class="form-control" autofocus>
    <span asp-validation-for="Nome" class="text-danger small fw-semibold"></span>
  </div>

  <div class="mb-3">
    <label asp-for="Email" class="form-label fw-semibold text-primary text-uppercase small">E-mail</label>
    <input asp-for="Email" type="email" class="form-control">
    <span asp-validation-for="Email" class="text-danger small fw-semibold"></span>
  </div>

  <div class="mb-3">
    <label asp-for="Senha" class="form-label fw-semibold text-primary text-uppercase small">Senha</label>
    <input asp-for="Senha" type="password" class="form-control">
    <span asp-validation-for="Senha" class="text-danger small fw-semibold"></span>
  </div>

  <div class="mb-3">
    <label asp-for="ConfirmarSenha" class="form-label fw-semibold text-primary text-uppercase small">Confirmar
      Senha</label>
      <input asp-for="ConfirmarSenha" type="password" class="form-control">
      <span asp-validation-for="ConfirmarSenha" class="text-danger small fw-semibold"></span>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4">
      <span class="text-muted small">
        Já tem conta? <a asp-action="Entrar" class="text-primary text-decoration-none fw-semibold">Entrar</a>
      </span>
      <button class="btn btn-primary px-4" type="submit">Criar Conta</button>
    </div>
  </form>
