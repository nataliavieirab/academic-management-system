@{
  Layout = "_Layout";
  ViewBag.Titulo = $"📋 Nova Matrícula — {Model.TurmaNome}";
  ViewBag.Info = "Selecione um aluno para matricular nesta turma.";
}

@model CadastrarMatriculaViewModel;

<form class="card border shadow-sm mx-auto p-4" style="max-width: 620px;"
      asp-action="Cadastrar" method="post">
  <input type="hidden" asp-for="TurmaId" />

  <div class="mb-3">
    <label class="form-label fw-semibold text-primary text-uppercase small">Turma</label>
    <input type="text" class="form-control" value="@Model.TurmaNome" disabled>
    <span asp-validation-for="TurmaId" class="text-danger small fw-semibold"></span>
  </div>

  <div class="mb-3">
    <label asp-for="AlunoId" class="form-label fw-semibold text-primary text-uppercase small">Aluno</label>
    <select asp-for="AlunoId" class="form-select"
            asp-items='@(new SelectList(Model.Alunos ?? new List<OpcaoAlunoViewModel>(), "Id", "Nome"))'>
      <option value="">Selecione um aluno</option>
    </select>
    <span asp-validation-for="AlunoId" class="text-danger small fw-semibold"></span>
  </div>

  <div class="d-flex justify-content-end gap-2 mt-4">
    <a class="btn btn-outline-secondary rounded-2 px-4"
       asp-action="Listar" asp-route-turmaId="@Model.TurmaId">Voltar</a>
    <button class="btn btn-primary rounded-2 px-4" type="submit">Matricular</button>
  </div>
</form>
