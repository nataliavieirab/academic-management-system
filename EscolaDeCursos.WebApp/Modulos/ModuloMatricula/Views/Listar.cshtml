@using EscolaDeCursos.Dominio.Modulos.ModuloMatricula
@model ListarMatriculasPaginaViewModel
@{
  Layout = "_Layout";
  ViewBag.Titulo = $"📝 Matrículas — {Model.TurmaNome}";
  ViewBag.Info = "Visualize e gerencie as matrículas desta turma.";
  ViewBag.TextoBotao = "Nova Matricula";
  ViewBag.ControllerBotao = "Matricula";
  ViewBag.ActionBotao = "Cadastrar";
  ViewBag.IdBotao = Model.TurmaId;
}

<form method="get" asp-action="Listar" class="row g-2 align-items-end mb-4 mt-1">
  <input type="hidden" asp-for="TurmaId" />
  <div class="col-md-4">
    <label asp-for="Situacao" class="form-label fw-semibold text-body-secondary small">Situação</label>
    <select asp-for="Situacao" class="form-select" asp-items="Html.GetEnumSelectList<SituacaoAluno>()">
      <option value="">Todas</option>
    </select>
  </div>
  <div class="col-md-auto">
    <button type="submit" class="btn btn-dark">Filtrar</button>
  </div>
</form>

<hr>

@if (TempData["MensagemErro"] is string mensagemErro)
{
  <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
    @mensagemErro
  </div>
}

@if (TempData["MensagemSucesso"] is string mensagemSucesso)
{
  <div class="alert alert-success border-start border-success border-4 rounded-3" role="alert">
    @mensagemSucesso
  </div>
}

@if (Model.Matriculas.Count == 0)
{
  <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
    @(Model.Situacao is null
      ? "Nenhuma matrícula cadastrada."
      : "Nenhuma matrícula encontrada para este filtro.")
  </div>
}
else
{
  <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2 mt-2">
    @foreach (ListarMatriculasViewModel m in Model.Matriculas)
    {
      <div class="col">
        <div class="card h-100">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-3">
              <h5 class="card-title fw-semibold text-dark medium">@m.AlunoNome</h5>
            </div>
            <hr class="my-1">

            <dl class="row g-2 mb-4 mt-2">
              <dt class="col-4 text-body-secondary fw-bold">Matrícula:</dt>
              <dd class="col-8 mb-0"><span class="badge text-bg-primary rounded-pill">@m.Id.ToString()[..8]</span></dd>

              <dt class="col-4 text-body-secondary fw-bold">Data:</dt>
              <dd class="col-8 mb-0">@m.Data.ToString("dd/MM/yyyy")</dd>

              <dt class="col-4 text-body-secondary fw-bold">Situação:</dt>
              <dd class="col-8 mb-0">
                @{
                  var situacaoBadge = m.Situacao switch
                  {
                    SituacaoAluno.Ativa => "text-bg-warning",
                    SituacaoAluno.Cancelada => "text-bg-danger",
                    SituacaoAluno.Concluida => "text-bg-success",
                    _ => "text-bg-secondary"
                  };
                }
                <span class="badge @situacaoBadge rounded-pill">@m.Situacao</span>
              </dd>
            </dl>

            <div class="d-flex flex-wrap gap-2 mt-auto justify-content-end">
              <a asp-action="Editar" asp-route-id="@m.Id" class="btn btn-primary" title="Editar">
                <i class="bi bi-pencil-square"></i>
              </a>
            </div>
          </div>
        </div>
      </div>
    }
  </div>
}

<div class="mt-4">
  <a class="btn btn-outline-secondary rounded-2 px-4" asp-controller="Turma" asp-action="Listar">Voltar</a>
</div>
