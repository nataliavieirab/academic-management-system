@using EscolaDeCursos.Dominio.Modulos.ModuloCurso
@model ListarCursosPaginaViewModel
@{
  Layout = "_Layout";
  ViewBag.Titulo = "📚 Cursos";
  ViewBag.Info = "Cadastre, visualize e gerencie os cursos.";
  ViewBag.TextoBotao = "Cadastrar Curso";
  ViewBag.ControllerBotao = "Curso";
  ViewBag.ActionBotao = "Cadastrar";
}

<form method="get" asp-action="Listar" class="row g-2 align-items-end mb-4 mt-1">
  <div class="col-md-3">
    <label asp-for="CategoriaId" class="form-label fw-semibold text-secondary small">Categoria</label>
    <select asp-for="CategoriaId" class="form-select" asp-items="Model.Categorias">
      <option value="">Todos</option>
    </select>
  </div>
  <div class="col-md-3">
    <label asp-for="Nivel" class="form-label fw-semibold text-secondary small">Nível</label>
    <select asp-for="Nivel" class="form-select" asp-items="Html.GetEnumSelectList<Nivel>()">
      <option value="">Todos</option>
    </select>
  </div>
  <div class="col-md-3">
    <label asp-for="FiltroTurmas" class="form-label fw-semibold text-secondary small">Turmas</label>
    <select asp-for="FiltroTurmas" class="form-select" asp-items="Html.GetEnumSelectList<FiltroTurmasCurso>()">
      <option value="">Todos</option>
    </select>
  </div>
  <div class="col-md-auto">
    <button type="submit" class="btn btn-dark">Filtrar</button>
  </div>
</form>
<hr>

@if (TempData["MensagemErro"] is string mensagemErro)
{
  <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
    @mensagemErro
  </div>
}

@if (Model.Cursos.Count == 0)
{
  <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
    @(Model.Nivel is null
      && Model.FiltroTurmas is null
      && (Model.CategoriaId is null || Model.CategoriaId == Guid.Empty)
      ? "Nenhum curso cadastrado."
      : "Nenhum curso encontrado para este filtro.")
</div>
}
else
{
  <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2 mt-2">
    @foreach (ListarCursosViewModel c in Model.Cursos)
    {
      <div class="col">
        <div class="card h-100">
          <div class="card-body d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start gap-3">
              <h5 class="card-title fw-semibold text-dark medium">@c.Titulo</h5>
            </div>
            <hr class="my-1">

            <dl class="row g-2 mb-4 mt-2">
              <dt class="col-4 text-secondary fw-bold">Descrição:</dt>
              <dd class="col-8 mb-0 text-break">@c.Descricao</dd>

              <dt class="col-4 text-secondary fw-bold">Categoria:</dt>
              <dd class="col-8 mb-0 text-break">@c.CategoriaTitulo</dd>

              <dt class="col-4 text-secondary fw-bold">Nível:</dt>
              <dd class="col-8 mb-0 text-break">@c.Nivel</dd>

              <dt class="col-4 text-secondary fw-bold">Carga Horária:</dt>
              <dd class="col-8 mb-0 text-break">@c.CargaHoraria h</dd>
            </dl>

            <div class="d-flex flex-wrap gap-2 mt-auto justify-content-between align-items-center">
              <div class="d-flex flex-wrap gap-2">
                <a asp-action="excluir" asp-route-id="@c.Id" class="btn btn-danger" title="Excluir">
                  <i class="bi bi-trash"></i>
                </a>
                <a asp-action="editar" asp-route-id="@c.Id" class="btn btn-success" title="Editar">
                  <i class="bi bi-pencil-square"></i>
                </a>
              </div>
              <a asp-controller="Modulo" asp-action="Listar" asp-route-cursoId="@c.Id" class="btn btn-primary fw-semibold"
                title="Módulos">
                <i class="bi bi-list-ol px-1"></i> Módulos
              </a>
            </div>
          </div>
        </div>
      </div>
    }
  </div>
}
