@{
  Layout = "_Layout";
  ViewBag.Titulo = "📚 Cursos";
  ViewBag.Info = "Cadastre, visualize e gerencie os cursos.";
  ViewBag.TextoBotao = "Cadastrar Curso";
  ViewBag.ControllerBotao = "Curso";
  ViewBag.ActionBotao = "Cadastrar";
}

@model List<ListarCursosViewModel>;

@if (TempData["MensagemErro"] is string mensagemErro)
{
  <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
    @mensagemErro
  </div>
}

@if (Model.Count == 0)
{
  <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
    Nenhum curso cadastrado.
  </div>
}
else
{
  <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2">
    @foreach (ListarCursosViewModel c in Model)
    {
      <div class="col">
        <div class="card h-100">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-3">
              <h5 class="card-title fw-semibold text-dark medium">@c.Titulo</h5>
            </div>
            <hr class="my-1">

            <dl class="row g-2 mb-4 mt-2">
              <dt class="col-4 text-secondary fw-bold">Categoria:</dt>
              <dd class="col-8 mb-0 text-break">@c.CategoriaTitulo</dd>

              <dt class="col-4 text-secondary fw-bold">Nível:</dt>
              <dd class="col-8 mb-0 text-break">@c.Nivel</dd>

              <dt class="col-4 text-secondary fw-bold">Carga Horária:</dt>
              <dd class="col-8 mb-0 text-break">@c.CargaHoraria h</dd>
            </dl>

            <div class="d-flex flex-wrap gap-2 mt-auto justify-content-end">
              <a asp-controller="Modulo" asp-action="Listar" asp-route-cursoId="@c.Id" class="btn btn-outline-dark"
                 title="Módulos">
                <i class="bi bi-list-ol"></i> Módulos
              </a>
              <a asp-action="editar" asp-route-id="@c.Id" class="btn btn-primary" title="Editar">
                <i class="bi bi-pencil-square"></i>
              </a>
              <a asp-action="excluir" asp-route-id="@c.Id" class="btn btn-danger" title="Excluir">
                <i class="bi bi-trash"></i>
              </a>
            </div>
          </div>
        </div>
      </div>
    }
  </div>
}
