@{
  Layout = "_Layout";
  ViewBag.Titulo = "🗑️ Excluir Curso";
  ViewBag.Info = "Confirme a exclusão deste curso.";
}

@model ExcluirCursoViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4 bg-transparent" style="max-width: 620px;"
      asp-action="Excluir" asp-route-id="@Model.Id" method="post">
  <div class="alert alert-warning border-start border-primary border-1 rounded-3" role="alert">
    Deseja realmente excluir este curso?
  </div>

  <div class="mb-3">
    <label asp-for="Titulo" class="form-label fw-semibold text-primary text-uppercase small">Título</label>
    <input asp-for="Titulo" type="text" class="form-control" disabled>
  </div>

  <div class="mb-3">
    <label asp-for="Descricao" class="form-label fw-semibold text-primary text-uppercase small">Descrição</label>
    <input asp-for="Descricao" type="text" class="form-control" disabled>
  </div>

  <div class="mb-3">
    <label asp-for="CategoriaTitulo" class="form-label fw-semibold text-primary text-uppercase small">Categoria</label>
    <input asp-for="CategoriaTitulo" type="text" class="form-control" disabled>
  </div>

  <div class="mb-3">
    <label asp-for="Nivel" class="form-label fw-semibold text-primary text-uppercase small">Nível</label>
    <input asp-for="Nivel" type="text" class="form-control" disabled>
  </div>

  <div class="mb-3">
    <label asp-for="CargaHoraria" class="form-label fw-semibold text-primary text-uppercase small">Carga Horária</label>
    <input asp-for="CargaHoraria" type="number" min="1" class="form-control" disabled>
  </div>

  <div class="d-flex justify-content-end gap-2 mt-4">
    <a class="btn btn-outline-secondary rounded-2 px-4" asp-action="Listar">Voltar</a>
    <button class="btn btn-primary rounded-2 px-4" type="submit">Confirmar</button>
  </div>
</form>
