@{
  Layout = "_Layout";
  ViewBag.Titulo = "🗑️ Excluir Módulo";
  ViewBag.Info = "Confirme a exclusão do módulo selecionado.";
}

@model ExcluirModuloViewModel;

<form class="card border shadow-sm mx-auto p-4" style="max-width: 620px;"
      asp-action="Excluir" asp-route-id="@Model.Id" method="post">
  <input asp-for="CursoId" type="hidden">

  <div class="alert alert-warning border-start border-primary border-1 rounded-3" role="alert">
    Deseja realmente excluir este módulo?
  </div>

  <div class="mb-3">
    <label asp-for="Titulo" class="form-label fw-semibold text-primary text-uppercase small">Título</label>
    <input asp-for="Titulo" type="text" class="form-control" disabled>
  </div>

  <div class="mb-3">
    <label asp-for="Descricao" class="form-label fw-semibold text-primary text-uppercase small">Descrição</label>
    <input asp-for="Descricao" type="text" class="form-control" disabled>
  </div>

  <div class="mb-3">
    <label asp-for="Ordem" class="form-label fw-semibold text-primary text-uppercase small">Numeração (Sequência do
      Módulo)</label>
      <input asp-for="Ordem" type="number" class="form-control" disabled>
    </div>

    <div class="mb-3">
      <label asp-for="Duracao" class="form-label fw-semibold text-primary text-uppercase small">Duração (horas)</label>
      <input asp-for="Duracao" type="number" min="1" class="form-control" disabled>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
      <a class="btn btn-outline-secondary rounded-2 px-4" asp-action="Listar"
         asp-route-cursoId="@Model.CursoId">Voltar</a>
      <button class="btn btn-primary rounded-2 px-4" type="submit">Confirmar</button>
    </div>
  </form>
