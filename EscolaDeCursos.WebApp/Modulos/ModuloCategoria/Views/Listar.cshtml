@using EscolaDeCursos.WebApp.Modulos.ModuloTurma
@model ListarCategoriasPaginaViewModel
@{
  Layout = "_Layout";
  ViewBag.Titulo = "🏷️ Categorias";
  ViewBag.Info = "Cadastre, visualize e gerencie categorias de cursos.";
  ViewBag.TextoBotao = "Cadastrar Categoria";
  ViewBag.ControllerBotao = "Categoria";
  ViewBag.ActionBotao = "Cadastrar";
}

<form method="get" asp-action="Listar" class="row g-2 align-items-end mb-4 mt-1">
  <div class="col-md-4">
    <label asp-for="CursoId" class="form-label fw-semibold text-secondary small">Curso</label>
    <select asp-for="CursoId" class="form-select"
      asp-items='@(new SelectList(Model.Cursos ?? new List<OpcaoCursoViewModel>(), "Id", "Titulo"))'>
      <option value="">Todas</option>
    </select>
  </div>
  <div class="col-md-auto">
    <button type="submit" class="btn btn-dark">Filtrar</button>
  </div>
</form>

<hr>

@if (TempData["MensagemErro"] is string mensagemErro)
{
  <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
    @mensagemErro
  </div>
}

@if (Model.Categorias.Count == 0)
{
  <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
    @(Model.CursoId is null || Model.CursoId == Guid.Empty
      ? "Nenhuma categoria cadastrada."
      : "Nenhuma categoria encontrada para este filtro.")
</div>
}
else
{
  <div class="row g-2 mt-2">
    @foreach (var c in Model.Categorias)
    {
      <div class="col-12 col-lg-6">
        <div class="card w-100">
          <div class="card-body d-flex justify-content-between align-items-center">

            <h5 class="card-title mb-0 fw-semibold">
              @c.Titulo
            </h5>

            <div class="d-flex gap-2">
              <a asp-action="editar" asp-route-id="@c.Id" class="btn btn-success">
                <i class="bi bi-pencil-square"></i>
              </a>

              <a asp-action="excluir" asp-route-id="@c.Id" class="btn btn-danger">
                <i class="bi bi-trash"></i>
              </a>
            </div>

          </div>
        </div>
      </div>
    }
  </div>
}
