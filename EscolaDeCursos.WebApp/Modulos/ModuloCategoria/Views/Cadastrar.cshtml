@{
  Layout = "_Layout";
  ViewBag.Titulo = "📋 Cadastrar Categoria";
  ViewBag.Info = "Registre as informações da nova categoria.";
}

@model CadastrarCategoriaViewModel;

<form class="card border shadow-sm mx-auto p-4" style="max-width: 620px;"
      asp-action="Cadastrar" method="post">
  <div class="mb-3">
    <label asp-for="Titulo" class="form-label fw-semibold text-primary text-uppercase small">Título</label>
    <input asp-for="Titulo" type="text" class="form-control">
    <span asp-validation-for="Titulo" class="text-danger small fw-semibold"></span>
  </div>

  <div class="d-flex justify-content-end gap-2 mt-4">
    <a class="btn btn-outline-secondary rounded-2 px-4" asp-action="Listar">Voltar</a>
    <button class="btn btn-primary rounded-2 px-4" type="submit">Confirmar</button>
  </div>
</form>
