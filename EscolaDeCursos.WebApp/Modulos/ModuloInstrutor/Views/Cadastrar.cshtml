@{
Layout = "_Layout";
ViewBag.Titulo = "📋 Cadastrar Instrutor";
ViewBag.Info = "Registre as informações do novo instrutor.";
}

@model CadastrarInstrutorViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4 bg-transparent" style="max-width: 620px;"
    asp-action="Cadastrar" method="post">
    <div class="mb-3">
        <label asp-for="Nome" class="form-label fw-semibold text-primary text-uppercase small">Nome</label>
        <input asp-for="Nome" type="text" class="form-control">
        <span asp-validation-for="Nome" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Cpf" class="form-label fw-semibold text-primary text-uppercase small">Cpf</label>
        <input asp-for="Cpf" type="text" class="form-control">
        <span asp-validation-for="Cpf" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Telefone" class="form-label fw-semibold text-primary text-uppercase small">Telefone</label>
        <input asp-for="Telefone" type="text" class="form-control">
        <span asp-validation-for="Telefone" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label fw-semibold text-primary text-uppercase small">E-mail</label>
        <input asp-for="Email" type="text" class="form-control">
        <span asp-validation-for="Email" class="text-danger small fw-semibold"></span>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-secondary rounded-2 px-4" asp-action="Listar">Voltar</a>
        <button class="btn btn-primary rounded-2 px-4" type="submit">Confirmar</button>
    </div>
</form>