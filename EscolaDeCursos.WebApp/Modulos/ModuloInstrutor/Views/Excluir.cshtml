@{
Layout = "_Layout";
ViewBag.Titulo = "🗑️ Excluir Instrutor";
ViewBag.Info = "Confirme a exclusão deste instrutor.";
}

@model ExcluirInstrutorViewModel;

<form class="card border shadow-sm mx-auto p-4" style="max-width: 620px;"
    asp-action="Excluir" asp-route-id="@Model.Id" method="post">
    <div class="alert alert-warning border-start border-primary border-1 rounded-3" role="alert">
        Deseja realmente excluir este instrutor?
    </div>

    <div class="mb-3">
        <label asp-for="Nome" class="form-label fw-semibold text-primary text-uppercase small">Nome</label>
        <input asp-for="Nome" type="text" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label asp-for="Cpf" class="form-label fw-semibold text-primary text-uppercase small">CPF</label>
        <input asp-for="Cpf" type="text" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label asp-for="Telefone" class="form-label fw-semibold text-primary text-uppercase small">Telefone</label>
        <input asp-for="Telefone" type="text" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label fw-semibold text-primary text-uppercase small">E-mail</label>
        <input asp-for="Email" type="text" class="form-control" disabled>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-secondary rounded-2 px-4" asp-action="Listar">Voltar</a>
        <button class="btn btn-primary rounded-2 px-4" type="submit">Confirmar</button>
    </div>
</form>