<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

  <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />

  <title>@ViewBag.Titulo Escola de Cursos</title>
</head>

<body class="@ViewData["BodyClass"]">
  @{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
  }

  @* Barra de Navegação *@
  <nav class="navbar navbar-expand-lg site-navbar">
    <div class="container">
      <a class="navbar-brand" asp-controller="Home" asp-action="Index">Escola de Cursos</a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal"
        aria-controls="menuPrincipal" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="menuPrincipal">
        @if (User.Identity?.IsAuthenticated == true)
        {
          <div class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
            <a class="nav-link @(currentController == "Home" ? "nav-pill-active" : null)" asp-controller="Home"
              asp-action="Index">Início</a>
            <a class="nav-link @(currentController == "Curso" || currentController == "Modulo" ? "nav-pill-active" : null)"
              asp-controller="Curso" asp-action="Listar">Cursos</a>
            <a class="nav-link @(currentController == "Categoria" ? "nav-pill-active" : null)" asp-controller="Categoria"
              asp-action="Listar">Categorias</a>
            <a class="nav-link @(currentController == "Turma" || currentController == "Matricula" ? "nav-pill-active" : null)"
              asp-controller="Turma" asp-action="Listar">Turmas</a>
            <a class="nav-link @(currentController == "Aluno" ? "nav-pill-active" : null)" asp-controller="Aluno"
              asp-action="Listar">Alunos</a>
            <a class="nav-link @(currentController == "Instrutor" ? "nav-pill-active" : null)" asp-controller="Instrutor"
              asp-action="Listar">Instrutores</a>
          </div>

          <div class="dropdown ms-lg-3">
            <button class="btn btn-outline-secondary btn-sm dropdown-toggle fw-medium" type="button"
              data-bs-toggle="dropdown" aria-expanded="false">
              @User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
              <li>
                <form asp-controller="Autenticacao" asp-action="Sair" method="post" class="d-inline">
                  <button type="submit" class="dropdown-item text-danger fw-semibold">Sair</button>
                </form>
              </li>
            </ul>
          </div>
        }
        else
        {
          <div class="navbar-nav ms-auto align-items-lg-center">
            <a class="nav-link @(currentController == "Autenticacao" ? "nav-pill-active" : null)"
              asp-controller="Autenticacao" asp-action="Entrar">Entrar</a>
          </div>
        }
      </div>
    </div>
  </nav>

  @* Cabeçalho da Página *@
  @if (!string.IsNullOrEmpty(ViewBag.Titulo as string))
  {
    <header class="container py-4 mt-4">
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3">
        <div>
          <h2 class="fw-semibold page-title">@ViewBag.Titulo</h2>
          @if (!string.IsNullOrEmpty(ViewBag.Info as string))
          {
            <p class="mb-0 page-info">@ViewBag.Info</p>
          }
        </div>
        @if (ViewBag.TextoBotao != null)
        {
          <a class="btn btn-primary px-4 align-self-start mt-md-4" asp-controller="@ViewBag.ControllerBotao"
            asp-action="@ViewBag.ActionBotao" asp-route-id="@ViewBag.IdBotao">
            @ViewBag.TextoBotao
          </a>
        }
      </div>
    </header>
  }

  @* Conteúdo da Página *@
  <main class="container pb-5">
    @RenderBody()
  </main>

  @* Importação do JavaScript do Bootstrap *@
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
    crossorigin="anonymous"></script>
</body>

</html>
