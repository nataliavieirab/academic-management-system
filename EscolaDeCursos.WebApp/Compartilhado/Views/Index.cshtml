@{
  Layout = "_Layout";
  ViewData["BodyClass"] = "page-mint";
}

<section class="row hero g-4 g-lg-5">
  <div class="col-lg-4 d-flex flex-column justify-content-start hero-copy">
    <h1 class="display-5 hero-title mb-3">Escola de Cursos</h1>
    <p class="hero-lead mb-4">
      Facilite a gestão da sua escola organizando cursos, turmas e matrículas, acompanhando instrutores e alunos com
      eficiência e clareza.
    </p>

    <div class="d-flex flex-wrap align-items-center gap-3 hero-actions">
      <a class="btn btn-primary btn-hero-primary" asp-controller="Autenticacao" asp-action="Entrar">Entrar</a>
      <a class="link-hero-secondary" asp-controller="Autenticacao" asp-action="Registrar">Criar Conta</a>
    </div>

    @* <ul class="hero-dots" aria-hidden="true">
      <li><span class="hero-dot is-active"></span></li>
      <li><span class="hero-dot"></span></li>
      <li><span class="hero-dot"></span></li>
      <li><span class="hero-dot"></span></li>
    </ul> *@
  </div>

  <div class="col-lg-8 hero-visual">
    <img src="~/img/students.png" alt="Ilustração de estudantes" class="hero-img" />
  </div>
</section>
